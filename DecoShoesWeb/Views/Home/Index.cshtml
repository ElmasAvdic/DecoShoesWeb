</style>

<div class="shop-shell">
    <div class="promo-bar">Besplatna impregnacija obuće za registrovane kupce</div>

    <div class="store-header">
        <nav class="audience-nav" aria-label="Glavne kategorije">
            @foreach (var category in rootCategories)
            {
                var isActive = selectedRootCategoryId == category.CategoryID || selectedCategoryId == category.CategoryID;
                var children = subcategoriesByParent.ContainsKey(category.CategoryID) ? subcategoriesByParent[category.CategoryID] : new List<Category>();
                <div class="audience-item">
                    <a class="audience-link @(isActive ? "active" : "")" href="@Url.Action("Index", "Home", new { categoryId = category.CategoryID, filter = currentFilter, search = currentSearch, size = currentSize, color = currentColor, minPrice = currentMinPrice, maxPrice = currentMaxPrice, sort = currentSort })">@category.Name</a>
                    @if (children.Any())
                    {
                        <div class="audience-dropdown">
                            @foreach (var child in children)
                            {
                                <a class="@(selectedCategoryId == child.CategoryID ? "active" : "")" href="@Url.Action("Index", "Home", new { categoryId = child.CategoryID, filter = currentFilter, search = currentSearch, size = currentSize, color = currentColor, minPrice = currentMinPrice, maxPrice = currentMaxPrice, sort = currentSort })">@child.Name</a>
                            }
                        </div>
                    }
                </div>
            }
        </nav>

        <a class="brand-mark" href="@Url.Action("Index", "Home")"><span class="brand-icon">D</span><span>DECOSHOES</span></a>

        <nav class="utility-nav" aria-label="Korisničke akcije">
            <a class="utility-link" href="@storeMapUrl" target="_blank" rel="noopener" title="Lokacija Zavidovići"><span class="utility-text">BiH</span></a>
            <a class="utility-link" href="@storeMapUrl" target="_blank" rel="noopener" title="Lokacija Zavidovići"><svg class="utility-icon" viewBox="0 0 24 24"><path d="M21 10c0 7-9 12-9 12S3 17 3 10a9 9 0 1 1 18 0Z"/><circle cx="12" cy="10" r="3"/></svg></a>
            @if (string.IsNullOrWhiteSpace(customerName))
            {
                <button class="utility-link utility-button" type="button" onclick="openAccountModal('login')" title="Prijava"><svg class="utility-icon" viewBox="0 0 24 24"><path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="7" r="4"/></svg></button>
            }
            else
            {
                <div class="utility-item">
                    <button class="utility-link utility-button" type="button" title="Moj račun"><svg class="utility-icon" viewBox="0 0 24 24"><path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="7" r="4"/></svg></button>
                    <div class="utility-dropdown account-menu-dropdown">
                        <strong>Moj račun</strong>
                        <a asp-controller="Account" asp-action="MyOrders">Moje narudžbe</a>
                        <a asp-controller="Account" asp-action="Profile">Moji podaci</a>
                        <a class="logout-link" asp-controller="Account" asp-action="Logout">Odjava</a>
                    </div>
                </div>
            }
            <div class="utility-item">
                <a class="utility-link" asp-controller="Wishlist" asp-action="Index" title="Lista želja"><svg class="utility-icon" viewBox="0 0 24 24"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8Z"/></svg>@if (wishlistCount > 0){<span class="icon-count">@wishlistCount</span>}</a>
                <div class="utility-dropdown">
                    @if (wishlistCount == 0)
                    {
                        <div class="dropdown-icon"><svg viewBox="0 0 24 24"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8Z"/></svg></div>
                        <strong>Tvoja lista želja je prazna</strong>
                        <p>Označi svoje omiljene predmete srcem da ih sačuvaš ovdje.</p>
                    }
                    else
                    {
                        <div class="dropdown-icon"><svg viewBox="0 0 24 24"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8Z"/></svg></div>
                        <strong>@wishlistCount proizvoda u listi želja</strong>
                        <p>Otvori listu želja da nastaviš kupovinu.</p>
                    }
                </div>
            </div>
            <div class="utility-item">
                <a class="utility-link" asp-controller="Cart" asp-action="Index" title="Korpa"><svg class="utility-icon" viewBox="0 0 24 24"><path d="M6 8h12l-1 13H7L6 8Z"/><path d="M9 8a3 3 0 0 1 6 0"/></svg>@if (cartCount > 0){<span class="icon-count">@cartCount</span>}</a>
                <div class="utility-dropdown cart-menu-dropdown">
                    @if (cartCount == 0)
                    {
                        <div class="dropdown-icon"><svg viewBox="0 0 24 24"><path d="M6 8h12l-1 13H7L6 8Z"/><path d="M9 8a3 3 0 0 1 6 0"/></svg></div>
                        <strong>Tvoja korpa je prazna</strong>
                        <p>Dodaj proizvod u korpu i on će se pojaviti ovdje.</p>
                    }
                    else
                    {
                        <div class="dropdown-icon"><svg viewBox="0 0 24 24"><path d="M6 8h12l-1 13H7L6 8Z"/><path d="M9 8a3 3 0 0 1 6 0"/></svg></div>
                        <strong class="cart-menu-title">@cartCount proizvoda u korpi</strong>
                        <div class="cart-preview-list">
                            @foreach (var cartItem in cartItems.Take(3))
                            {
                                <div class="cart-preview-item">
                                    <div class="cart-preview-image">
                                        @if (!string.IsNullOrWhiteSpace(cartItem.ImageUrl))
                                        {
                                            <img src="@cartItem.ImageUrl" alt="@cartItem.ProductName" />
                                        }
                                        else
                                        {
                                            <span>Nema slike</span>
                                        }
                                    </div>
                                    <div class="cart-preview-info">
                                        <b>@cartItem.ProductName</b>
                                        <span>@(string.IsNullOrWhiteSpace(cartItem.Size) ? "Bez veličine" : $"Broj: {cartItem.Size}")</span>
                                        <span>@cartItem.Quantity x @cartItem.Price.ToString("0.00") BAM</span>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="cart-preview-total">
                            <span>Ukupno</span>
                            <strong>@cartItems.Sum(item => item.Total).ToString("0.00") BAM</strong>
                        </div>
                        <a class="cart-preview-button" asp-controller="Cart" asp-action="Index">Otvori korpu i završi narudžbu</a>
                    }
                </div>
            </div>
        </nav>
    <div class="account-modal-backdrop @(isAccountModalOpen ? "is-open" : "")" id="accountModal" aria-hidden="@(isAccountModalOpen ? "false" : "true")">
        <div class="account-modal" role="dialog" aria-modal="true" aria-labelledby="accountModalTitle">
            <button class="account-modal-close" type="button" onclick="closeAccountModal()" aria-label="Zatvori">&times;</button>
            <div class="account-modal-title" id="accountModalTitle">Prijava</div>

            @if (!string.IsNullOrWhiteSpace(accountError))
            {
                <div class="account-error">@accountError</div>
            }

            <form class="account-form" id="loginForm" asp-controller="Account" asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <label for="loginEmail">Email adresa</label>
                <input id="loginEmail" name="Email" type="email" autocomplete="email" placeholder="Upiši svoj email" required />
                <button class="account-submit" type="submit">Prijava</button>
                <div class="account-switch">Nemaš račun? <button type="button" onclick="switchAccountMode('register')">Registruj se</button></div>
            </form>

            <form class="account-form" id="registerForm" asp-controller="Account" asp-action="Register" method="post">
                @Html.AntiForgeryToken()
                <div class="account-grid">
                    <div>
                        <label for="registerFirstName">Ime</label>
                        <input id="registerFirstName" name="FirstName" type="text" autocomplete="given-name" required />
                    </div>
                    <div>
                        <label for="registerLastName">Prezime</label>
                        <input id="registerLastName" name="LastName" type="text" autocomplete="family-name" required />
                    </div>
                </div>
                <label for="registerEmail">Email adresa</label>
                <input id="registerEmail" name="Email" type="email" autocomplete="email" required />
                <label for="registerPhone">Telefon</label>
                <input id="registerPhone" name="Phone" type="tel" autocomplete="tel" />
                <label for="registerAddress">Adresa</label>
                <input id="registerAddress" name="Address" type="text" autocomplete="street-address" />
                <div class="account-grid">
                    <div>
                        <label for="registerCity">Grad</label>
                        <input id="registerCity" name="City" type="text" autocomplete="address-level2" />
                    </div>
                    <div>
                        <label for="registerPostalCode">Poštanski broj</label>
                        <input id="registerPostalCode" name="PostalCode" type="text" autocomplete="postal-code" />
                    </div>
                </div>
                <button class="account-submit" type="submit">Registracija</button>
                <div class="account-switch">Već imaš račun? <button type="button" onclick="switchAccountMode('login')">Prijavi se</button></div>
            </form>
        </div>
    </div>

    </div>

    <div class="category-bar">
        <nav class="category-nav" aria-label="Filteri proizvoda">
            <a class="category-link @(!isHomeShowcase && currentFilter == null ? "active" : "")" href="@Url.Action("Index", "Home", new { categoryId = activeCategoryRouteId, search = currentSearch, size = currentSize, color = currentColor, minPrice = currentMinPrice, maxPrice = currentMaxPrice, sort = currentSort, showAll = true })">Sve</a>
            <a class="category-link @(currentFilter == "new" ? "active" : "")" href="@Url.Action("Index", "Home", new { categoryId = activeCategoryRouteId, filter = "new", search = currentSearch, size = currentSize, color = currentColor, minPrice = currentMinPrice, maxPrice = currentMaxPrice, sort = currentSort })">Novo</a>
            <a class="category-link discount @(currentFilter == "discounted" ? "active" : "")" href="@Url.Action("Index", "Home", new { categoryId = activeCategoryRouteId, filter = "discounted", search = currentSearch, size = currentSize, color = currentColor, minPrice = currentMinPrice, maxPrice = currentMaxPrice, sort = currentSort })">Sniženo %</a>
            <a class="refresh-view-link" href="@Url.Action("Index", "Home")">Osvježi prikaz</a>
        </nav>

        <form class="search-box" asp-controller="Home" asp-action="Index" method="get">
            @if (activeCategoryRouteId.HasValue) { <input type="hidden" name="categoryId" value="@activeCategoryRouteId.Value" /> }
            @if (!string.IsNullOrWhiteSpace(currentFilter)) { <input type="hidden" name="filter" value="@currentFilter" /> }
            @if (!string.IsNullOrWhiteSpace(currentSize)) { <input type="hidden" name="size" value="@currentSize" /> }
            @if (!string.IsNullOrWhiteSpace(currentColor)) { <input type="hidden" name="color" value="@currentColor" /> }
            @if (currentMinPrice.HasValue) { <input type="hidden" name="minPrice" value="@currentMinPrice.Value" /> }
            @if (currentMaxPrice.HasValue) { <input type="hidden" name="maxPrice" value="@currentMaxPrice.Value" /> }
            @if (!string.IsNullOrWhiteSpace(currentSort)) { <input type="hidden" name="sort" value="@currentSort" /> }
            <svg class="utility-icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
            <input type="search" name="search" value="@currentSearch" placeholder="Pretraži proizvode" />
            <button type="submit">Traži</button>
        </form>
    </div>

    <div class="shop-controls">
        <div class="shop-controls-row">
            <button class="filter-toggle" type="button" onclick="toggleFilterPanel()">Filteri</button>

            <form class="sort-form" asp-controller="Home" asp-action="Index" method="get">
                @if (activeCategoryRouteId.HasValue) { <input type="hidden" name="categoryId" value="@activeCategoryRouteId.Value" /> }
                @if (!string.IsNullOrWhiteSpace(currentFilter)) { <input type="hidden" name="filter" value="@currentFilter" /> }
                @if (!string.IsNullOrWhiteSpace(currentSearch)) { <input type="hidden" name="search" value="@currentSearch" /> }
                @if (!string.IsNullOrWhiteSpace(currentSize)) { <input type="hidden" name="size" value="@currentSize" /> }
                @if (!string.IsNullOrWhiteSpace(currentColor)) { <input type="hidden" name="color" value="@currentColor" /> }
                @if (currentMinPrice.HasValue) { <input type="hidden" name="minPrice" value="@currentMinPrice.Value" /> }
                @if (currentMaxPrice.HasValue) { <input type="hidden" name="maxPrice" value="@currentMaxPrice.Value" /> }
                <label for="sort">Razvrstajte</label>
                <select id="sort" name="sort" onchange="this.form.requestSubmit()">
                    <option value="" selected="@string.IsNullOrWhiteSpace(currentSort)">Bez razvrstavanja</option>
                    <option value="price-asc" selected="@(currentSort == "price-asc")">Od najjeftinijeg</option>
                    <option value="price-desc" selected="@(currentSort == "price-desc")">Od najskupljeg</option>
                    <option value="newest" selected="@(currentSort == "newest")">Najnovije</option>
                    <option value="discount" selected="@(currentSort == "discount")">Najveći popust</option>
                </select>
            </form>
        </div>

        <form class="filter-panel @(hasAdvancedFilters ? "is-open" : "")" id="filterPanel" asp-controller="Home" asp-action="Index" method="get">
            @if (activeCategoryRouteId.HasValue) { <input type="hidden" name="categoryId" value="@activeCategoryRouteId.Value" /> }
            @if (!string.IsNullOrWhiteSpace(currentFilter)) { <input type="hidden" name="filter" value="@currentFilter" /> }
            @if (!string.IsNullOrWhiteSpace(currentSearch)) { <input type="hidden" name="search" value="@currentSearch" /> }
            @if (!string.IsNullOrWhiteSpace(currentSort)) { <input type="hidden" name="sort" value="@currentSort" /> }

            <div class="filter-field">
                <label for="size">Broj</label>
                <select id="size" name="size">
                    <option value="">Svi brojevi</option>
                    @foreach (var sizeOption in availableSizes)
                    {
                        <option value="@sizeOption" selected="@(currentSize == sizeOption)">@sizeOption</option>
                    }
                </select>
            </div>

            <div class="filter-field">
                <label for="color">Boja</label>
                <select id="color" name="color">
                    <option value="">Sve boje</option>
                    @foreach (var colorOption in availableColors)
                    {
                        <option value="@colorOption" selected="@(currentColor == colorOption)">@colorOption</option>
                    }
                </select>
            </div>

            <div class="filter-field">
                <label for="minPrice">Cijena od</label>
                <input id="minPrice" name="minPrice" type="number" step="0.01" min="0" value="@currentMinPriceText" placeholder="0" />
            </div>

            <div class="filter-field">
                <label for="maxPrice">Cijena do</label>
                <input id="maxPrice" name="maxPrice" type="number" step="0.01" min="0" value="@currentMaxPriceText" placeholder="100" />
            </div>

            <button class="filter-submit" type="submit">Primijeni</button>
            <a class="filter-clear" href="@Url.Action("Index", "Home", new { categoryId = activeCategoryRouteId, filter = currentFilter, search = currentSearch, sort = currentSort })">Očisti filtere</a>
        </form>
    </div>

    <div class="benefit-bar">
        <span>Besplatna dostava za narudžbe nad 29 KM</span>
        <span>Mogućnost povrata do 60 dana</span>
        <span>Dostava u 2 - 4 radna dana</span>
    </div>

    @if (isHomeShowcase)
    {
        <section class="home-showcase" aria-label="DecoShoes izlog">
            <img class="showcase-image showcase-image-wide" src="~/images/home/showcase-wide.png" alt="DecoShoes izlog" />

            <div class="products-grid showcase-grid">
                @foreach (var product in showcaseProducts.Take(4))
                {
                    <partial name="_ProductCard" model="product" />
                }
            </div>

            <div class="showcase-split">
                <img class="showcase-image showcase-image-side" src="~/images/home/showcase-left.png" alt="DecoShoes kolekcija" />
                <div class="showcase-products">
                    @foreach (var product in showcaseProducts.Skip(4).Take(3))
                    {
                        <partial name="_ProductCard" model="product" />
                    }
                </div>
            </div>

            <div class="products-grid showcase-grid">
                @foreach (var product in showcaseProducts.Skip(7).Take(4))
                {
                    <partial name="_ProductCard" model="product" />
                }
            </div>

            <div class="showcase-split showcase-split-reverse">
                <div class="showcase-products">
                    @foreach (var product in showcaseProducts.Skip(11).Take(3))
                    {
                        <partial name="_ProductCard" model="product" />
                    }
                </div>
                <img class="showcase-image showcase-image-side" src="~/images/home/showcase-right.png" alt="DecoShoes nova ponuda" />
            </div>
        </section>
    }
    else
    {
        <section class="products-section">
            <h2 class="products-title">
                @if (currentFilter == "new") { <span>Novo - @allProductsLabel</span> }
                else if (currentFilter == "discounted") { <span>Sniženo - @allProductsLabel</span> }
                else { <span>@allProductsLabel</span> }
            </h2>

            @if (Model.Count == 0)
            {
                <div class="no-products">Nema dostupnih proizvoda za odabrani filter.</div>
            }
            else
            {
                <div class="products-grid">
                    @foreach (var product in Model)
                    {
                        <partial name="_ProductCard" model="product" />
                    }
                </div>
            }
        </section>
    }
</div>

<script>
    const initialAccountMode = '@(accountModal == "register" ? "register" : "login")';

    function switchAccountMode(mode) {
        const loginForm = document.getElementById('loginForm');
        const registerForm = document.getElementById('registerForm');
        const modalTitle = document.getElementById('accountModalTitle');

        if (!loginForm || !registerForm) {
            return;
        }

        const isRegister = mode === 'register';
        loginForm.classList.toggle('active', !isRegister);
        registerForm.classList.toggle('active', isRegister);

        if (modalTitle) {
            modalTitle.textContent = isRegister ? 'Registracija' : 'Prijava';
        }
    }

    function openAccountModal(mode) {
        const modal = document.getElementById('accountModal');
        if (!modal) {
            return;
        }

        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
        switchAccountMode(mode || 'login');
    }

    function closeAccountModal() {
        const modal = document.getElementById('accountModal');
        if (!modal) {
            return;
        }

        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
    }

    function toggleFilterPanel() {
        const panel = document.getElementById('filterPanel');
        if (panel) {
            panel.classList.toggle('is-open');
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        switchAccountMode(initialAccountMode);

        const modal = document.getElementById('accountModal');
        if (modal && modal.classList.contains('is-open')) {
            switchAccountMode(initialAccountMode);
        }

        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape') {
                closeAccountModal();
            }
        });

        if (modal) {
            modal.addEventListener('click', function (event) {
                if (event.target === modal) {
                    closeAccountModal();
                }
            });
        }
    });

    function addToCart(productId, event) {
        event.preventDefault();
        event.stopPropagation();
        window.location.href = '@Url.Action("Details", "Products")' + '?id=' + productId + '&source=shop';
    }

    async function addToWishlist(productId, event) {
        event.preventDefault();
        event.stopPropagation();

        const button = event.currentTarget;
        const counter = document.querySelector('.utility-link[title="Lista želja"] .icon-count');

        try {
            await fetch('@Url.Action("Add", "Wishlist")' + '?productId=' + productId, {
                method: 'GET',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });

            if (!button.classList.contains('active')) {
                button.classList.add('active');

                if (counter) {
                    counter.textContent = (parseInt(counter.textContent || '0') + 1).toString();
                }
            }
        } catch {
            const returnUrl = encodeURIComponent(window.location.pathname + window.location.search);
            window.location.href = '@Url.Action("Add", "Wishlist")' + '?productId=' + productId + '&returnUrl=' + returnUrl;
        }
    }

    document.querySelectorAll('.customer-history-replace').forEach(link => {
        link.addEventListener('click', function (event) {
            event.preventDefault();
            window.location.href = this.href;
        });
    });

    document.querySelectorAll('.shop-shell a[href]').forEach(link => {
        link.addEventListener('click', function (event) {
            if (this.target === '_blank' || this.href.startsWith('mailto:') || this.href.startsWith('tel:')) {
                return;
            }

            if (this.origin === window.location.origin) {
                event.preventDefault();
                window.location.href = this.href;
            }
        });
    });

    const searchForm = document.querySelector('.search-box');
    if (searchForm) {
        searchForm.addEventListener('submit', function (event) {
            event.preventDefault();
            const formData = new FormData(this);
            const params = new URLSearchParams();

            formData.forEach((value, key) => {
                if (value) {
                    params.append(key, value);
                }
            });

            const query = params.toString();
            window.location.href = this.action + (query ? '?' + query : '');
        });
    }

    document.querySelectorAll('.shop-controls form').forEach(form => {
        form.addEventListener('submit', function (event) {
            event.preventDefault();
            const formData = new FormData(this);
            const params = new URLSearchParams();

            formData.forEach((value, key) => {
                if (value) {
                    params.append(key, value);
                }
            });

            const query = params.toString();
            window.location.href = this.action + (query ? '?' + query : '');
        });
    });
</script>

@model DecoShoesWeb.Models.Product

@{
    ViewData["Title"] = Model.Name;
    var source = Context.Request.Query["source"].ToString();
    var isAdminView = source == "admin";
    var similarProducts = ViewData["SimilarProducts"] as List<DecoShoesWeb.Models.Product> ?? new List<DecoShoesWeb.Models.Product>();
}

<h1>@Model.Name</h1>

@if (TempData["Message"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="product-details-page">
    <div class="product-gallery">
        <div class="main-image-box">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="main-product-image" alt="@Model.Name" />
            }
            else
            {
                <div class="no-image">Nema slike</div>
            }
        </div>
    </div>

    <div class="product-details-info">
        <p class="product-category">@(Model.Category?.Name ?? "Proizvod")</p>

        @if (Model.DiscountPercent != null && Model.DiscountPercent > 0)
        {
            var discountedPrice = Model.Price - (Model.Price * Model.DiscountPercent.Value / 100);
            <p class="old-price">@Model.Price BAM</p>
            <p class="details-price">@discountedPrice.ToString("0.00") BAM</p>
        }
        else
        {
            <p class="details-price">@Model.Price BAM</p>
        }

        <hr />

        <div id="stockMessage" class="alert alert-danger" style="display: none; margin-bottom: 15px;">
            <span id="stockMessageText"></span>
        </div>

        <form asp-controller="Cart" asp-action="AddToCart" method="post" onsubmit="return validateForm()" class="cart-form-panel">
            @Html.AntiForgeryToken()
            <input type="hidden" name="productId" value="@Model.ProductID" />

            @if (Model.HasSizes)
            {
                <h5>Izaberi veličinu</h5>

                <div class="size-grid">
                    @foreach (var size in Model.ProductSizes.OrderBy(s => s.Size))
                    {
                        if (size.StockQuantity > 0)
                        {
                            <label class="size-option">
                                <input type="radio" name="productSizeId" value="@size.ProductSizeID" data-stock="@size.StockQuantity" data-size="@size.Size" class="size-input" />
                                <span>@size.Size</span>
                            </label>
                        }
                        else
                        {
                            <div class="size-option disabled">
                                <span>@size.Size</span>
                            </div>
                        }
                    }
                </div>
            }
            else
            {
                <input type="hidden" id="productStock" value="@(Model.StockQuantity ?? 0)" />
            }

            <div class="quantity-box">
                <label>Količina</label>
                <input type="number" name="quantity" value="1" min="1" class="form-control" id="quantityInput" onchange="validateQuantity()" />
            </div>

            <button type="submit" class="btn btn-danger add-cart-btn" id="submitBtn">
                Dodaj u korpu
            </button>
        </form>

        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <div class="customer-description">
                <strong>Opis</strong>
                <p>@Model.Description</p>
            </div>
        }

        @if (isAdminView)
        {
            <a asp-action="Index" class="btn btn-outline-secondary back-products-btn">Nazad na proizvode</a>
        }
        else
        {
            <button type="button" class="btn btn-outline-secondary back-products-btn" onclick="goBackToShopping()">Nazad u kupovinu</button>
        }
    </div>
</div>

@if (!isAdminView && similarProducts.Any())
{
    <section class="similar-products-section">
        <h2>Slični proizvodi</h2>
        <div class="similar-products-grid">
            @foreach (var product in similarProducts)
            {
                var hasDiscount = product.DiscountPercent.HasValue && product.DiscountPercent > 0;
                var price = hasDiscount ? product.Price * (1 - product.DiscountPercent.Value / 100) : product.Price;

                <a class="similar-product-card customer-history-replace" asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductID" asp-route-source="shop">
                    <div class="similar-product-image">
                        @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                        {
                            <img src="@product.ImageUrl" alt="@product.Name" />
                        }
                        else
                        {
                            <span>Nema slike</span>
                        }
                    </div>
                    <div class="similar-product-info">
                        <strong>@product.Name</strong>
                        <span>@(product.Category?.Name ?? "Proizvod")</span>
                        <b>@price.ToString("0.00") BAM</b>
                    </div>
                </a>
            }
        </div>
    </section>
}

<style>
    .product-details-page {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 40px;
        margin-top: 30px;
    }

    .main-image-box {
        background: #f6f6f6;
        min-height: 620px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
    }

    .main-product-image {
        max-width: 90%;
        max-height: 560px;
        object-fit: contain;
    }

    .product-category {
        color: #777;
        margin-bottom: 4px;
    }

    .details-price {
        font-size: 22px;
        font-weight: 700;
        margin-top: 14px;
    }

    .old-price {
        text-decoration: line-through;
        color: #8f5962;
        margin-bottom: 2px;
    }

    .size-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 8px;
        margin-top: 14px;
        margin-bottom: 20px;
    }

    .size-option input {
        display: none;
    }

    .size-option span,
    .size-option.disabled span {
        display: block;
        border: 1px solid #ccc;
        padding: 14px;
        text-align: center;
        border-radius: 4px;
        cursor: pointer;
        font-weight: 600;
    }

    .size-option input:checked + span {
        border: 2px solid #d82736;
    }

    .size-option.disabled span {
        color: #aaa;
        background: #f2f2f2;
        text-decoration: line-through;
        cursor: not-allowed;
    }

    .quantity-box {
        margin-bottom: 20px;
    }

    .quantity-box input {
        max-width: 120px;
    }

    .add-cart-btn {
        width: 100%;
        padding: 15px;
        font-size: 17px;
        border-radius: 30px;
    }

    .customer-description {
        margin-top: 22px;
        padding: 16px 18px;
        background: #fff1f3;
        border: 1px solid #f7c9cf;
        border-radius: 6px;
    }

    .customer-description strong {
        display: block;
        margin-bottom: 6px;
    }

    .customer-description p {
        margin: 0;
    }

    .back-products-btn {
        margin-top: 22px;
        border-color: #d82736;
        color: #a91524;
        font-weight: 700;
    }

    .back-products-btn:hover {
        background: #fff1f3;
        border-color: #a91524;
        color: #8f1420;
    }

    .similar-products-section {
        margin-top: 36px;
        padding-top: 26px;
        border-top: 1px solid #f7c9cf;
    }

    .similar-products-section h2 {
        font-size: 24px;
        font-weight: 900;
        color: #211a1d;
        margin-bottom: 18px;
    }

    .similar-products-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
        align-items: start;
    }

    .similar-product-card {
        display: grid;
        gap: 10px;
        border: 1px solid #f7c9cf;
        border-radius: 6px;
        padding: 12px;
        color: #211a1d;
        text-decoration: none;
        background: #fff;
    }

    .similar-product-card:hover {
        border-color: #d82736;
        color: #211a1d;
        box-shadow: 0 10px 22px rgba(33, 26, 29, .1);
    }

    .similar-product-image {
        aspect-ratio: 4 / 3;
        background: #f6f6f6;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        color: #777;
        font-weight: 800;
    }

    .similar-product-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .similar-product-info {
        display: grid;
        gap: 4px;
    }

    .similar-product-info strong {
        font-size: 16px;
        line-height: 1.25;
    }

    .similar-product-info span {
        color: #6f3741;
        font-weight: 700;
        font-size: 13px;
    }

    .similar-product-info b {
        font-size: 17px;
    }

    #stockMessage {
        border-radius: 5px;
        padding: 12px 15px;
        font-weight: 500;
        margin-bottom: 15px;
    }

    #stockMessage.alert-danger {
        background-color: #f8d7da;
        border: 1px solid #f5c6cb;
        color: #721c24;
    }

    .add-cart-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed !important;
    }

    @@media (max-width: 900px) {
        .product-details-page {
            grid-template-columns: 1fr;
        }

        .main-image-box {
            min-height: 360px;
        }

        .similar-products-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 560px) {
        .similar-products-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<script>
    function validateForm() {
        const selectedSize = document.querySelector('input[name="productSizeId"]:checked');
        const quantity = parseInt(document.getElementById('quantityInput').value);
        const productStockInput = document.getElementById('productStock');
        const messageDiv = document.getElementById('stockMessage');
        const messageText = document.getElementById('stockMessageText');

        messageDiv.style.display = 'none';

        if (quantity < 1) {
            messageText.textContent = 'Količina mora biti najmanje 1!';
            messageDiv.style.display = 'block';
            return false;
        }

        if (productStockInput) {
            const stock = parseInt(productStockInput.value);

            if (quantity > stock) {
                messageText.textContent = `Nema dovoljno dostupnih komada. Dostupno je: ${stock}`;
                messageDiv.style.display = 'block';
                return false;
            }

            return true;
        }

        if (!selectedSize) {
            messageText.textContent = 'Molimo izaberite veličinu!';
            messageDiv.style.display = 'block';
            return false;
        }

        const stock = parseInt(selectedSize.getAttribute('data-stock'));
        const size = selectedSize.getAttribute('data-size');

        if (quantity > stock) {
            messageText.textContent = `Nema dovoljno dostupnih komada za veličinu ${size}. Dostupno je: ${stock}`;
            messageDiv.style.display = 'block';
            return false;
        }

        return true;
    }

    function validateQuantity() {
        const selectedSize = document.querySelector('input[name="productSizeId"]:checked');
        const quantity = parseInt(document.getElementById('quantityInput').value) || 1;
        const productStockInput = document.getElementById('productStock');
        const messageDiv = document.getElementById('stockMessage');
        const messageText = document.getElementById('stockMessageText');
        const submitBtn = document.getElementById('submitBtn');

        messageDiv.style.display = 'none';

        if (productStockInput) {
            const stock = parseInt(productStockInput.value);

            if (quantity > stock) {
                messageText.textContent = `Nema dovoljno dostupnih komada. Dostupno je: ${stock}`;
                messageDiv.style.display = 'block';
                submitBtn.disabled = true;
            } else if (quantity < 1) {
                messageText.textContent = 'Količina mora biti najmanje 1!';
                messageDiv.style.display = 'block';
                submitBtn.disabled = true;
            } else {
                submitBtn.disabled = false;
            }
        } else if (selectedSize) {
            const stock = parseInt(selectedSize.getAttribute('data-stock'));
            const size = selectedSize.getAttribute('data-size');

            if (quantity > stock) {
                messageText.textContent = `Nema dovoljno dostupnih komada za veličinu ${size}. Dostupno je: ${stock}`;
                messageDiv.style.display = 'block';
                submitBtn.disabled = true;
            } else if (quantity < 1) {
                messageText.textContent = 'Količina mora biti najmanje 1!';
                messageDiv.style.display = 'block';
                submitBtn.disabled = true;
            } else {
                submitBtn.disabled = false;
            }
        }
    }

    document.querySelectorAll('.size-input').forEach(input => {
        input.addEventListener('change', validateQuantity);
    });

    function goBackToShopping() {
        if (window.history.length > 1) {
            window.history.back();
            return;
        }

        window.location.href = '@Url.Action("Index", "Home")';
    }

    document.querySelectorAll('.customer-history-replace').forEach(link => {
        link.addEventListener('click', function (event) {
            event.preventDefault();
            window.location.href = this.href;
        });
    });

    window.addEventListener('load', validateQuantity);
</script>


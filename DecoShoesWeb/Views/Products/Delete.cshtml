@model DecoShoesWeb.Models.Product

@{
    ViewData["Title"] = "Obriši proizvod";
    var orderItemCount = (int)(ViewData["OrderItemCount"] ?? 0);
    var categoryName = Model.Category?.ParentCategory != null
        ? $"{Model.Category.ParentCategory.Name} > {Model.Category.Name}"
        : Model.Category?.Name ?? "-";
}

<div class="admin-delete-panel">
    <div class="admin-delete-header">
        <div>
            <h1>Obriši proizvod</h1>
            <p class="text-muted mb-0">Provjeri proizvod prije brisanja.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Nazad na proizvode</a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mt-3">@TempData["Error"]</div>
    }

    @if (orderItemCount > 0)
    {
        <div class="alert alert-warning mt-3">
            Ovaj proizvod postoji u @orderItemCount stavki narudžbe. Brisanjem proizvoda brišu se i te povezane stavke.
        </div>
    }

    <div class="delete-summary mt-4">
        <dl class="row mb-0">
            <dt class="col-sm-3">Naziv</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Kategorija</dt>
            <dd class="col-sm-9">@categoryName</dd>

            <dt class="col-sm-3">Brend</dt>
            <dd class="col-sm-9">@(Model.Brand ?? "-")</dd>

            <dt class="col-sm-3">Boja</dt>
            <dd class="col-sm-9">@(Model.Color ?? "-")</dd>

            <dt class="col-sm-3">Cijena</dt>
            <dd class="col-sm-9">@Model.Price.ToString("0.00") KM</dd>

            <dt class="col-sm-3">Popust</dt>
            <dd class="col-sm-9">@(Model.DiscountPercent.HasValue && Model.DiscountPercent > 0 ? $"{Model.DiscountPercent:0.##}%" : "-")</dd>

            <dt class="col-sm-3">Zaliha</dt>
            <dd class="col-sm-9">@(Model.StockQuantity?.ToString() ?? "-")</dd>

            <dt class="col-sm-3">Veličine</dt>
            <dd class="col-sm-9">@(Model.HasSizes ? "Da" : "Ne")</dd>
        </dl>
    </div>

    <form asp-action="Delete" class="mt-4">
        <input type="hidden" asp-for="ProductID" />
        <button type="submit" class="btn btn-danger">Obriši proizvod</button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Odustani</a>
    </form>
</div>

<style>
    .admin-delete-panel {
        max-width: 920px;
    }

    .admin-delete-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
    }

    .delete-summary {
        border: 1px solid #f7c9cf;
        background: #fff;
        padding: 20px;
        border-radius: 6px;
    }

    .delete-summary dt {
        color: #6f3741;
    }

    .btn-danger {
        background: #d82736;
        border-color: #d82736;
    }
</style>

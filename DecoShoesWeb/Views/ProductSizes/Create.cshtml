@model DecoShoesWeb.Models.ProductSize

@{
    ViewData["Title"] = "Dodaj broj proizvoda";
}

<h1>Dodaj broj proizvoda</h1>

<div class="admin-form-card">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="form-group mb-3">
            <label asp-for="ProductID" class="control-label">Proizvod</label>
            <select asp-for="ProductID" class="form-control" asp-items="ViewBag.ProductID"></select>
            <span asp-validation-for="ProductID" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Size" class="control-label">Broj / veličina</label>
            <input asp-for="Size" class="form-control" placeholder="npr. 42" />
            <span asp-validation-for="Size" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="StockQuantity" class="control-label">Količina u lageru</label>
            <input asp-for="StockQuantity" type="number" min="0" class="form-control" />
            <span asp-validation-for="StockQuantity" class="text-danger"></span>
        </div>

        <div class="admin-form-actions">
            <button type="submit" class="btn btn-primary">Sačuvaj</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Nazad na veličine</a>
        </div>
    </form>
</div>

<style>
    .admin-form-card { max-width: 680px; border: 1px solid #f7c9cf; border-radius: 6px; padding: 20px; background: #fff; }
    .admin-form-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 18px; }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

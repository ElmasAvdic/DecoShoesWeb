@model DecoShoesWeb.Models.Category

@{
    ViewData["Title"] = "Obrši kategoriju";
    var productCount = (int)(ViewData["ProductCount"] ?? 0);
    var subcategoryCount = (int)(ViewData["SubcategoryCount"] ?? 0);
}

<h1>Obriši kategoriju</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="delete-category-panel">
    <h4>@Model.Name</h4>
    <p class="text-muted">@(Model.ParentCategory?.Name == null ? "Glavna kategorija" : $"Podkategorija u: {Model.ParentCategory.Name}")</p>

    <dl class="row">
        <dt class="col-sm-3">Naziv za link</dt>
        <dd class="col-sm-9">@Model.Slug</dd>

        <dt class="col-sm-3">Podkategorije</dt>
        <dd class="col-sm-9">@subcategoryCount</dd>

        <dt class="col-sm-3">Proizvodi</dt>
        <dd class="col-sm-9">@productCount</dd>
    </dl>

    @if (productCount > 0)
    {
        <div class="alert alert-warning">
            Ovu kategoriju ne možeš obrisati dok ima proizvode. Prvo uredi proizvode i prebaci ih u drugu kategoriju.
        </div>
    }
    else if (subcategoryCount > 0)
    {
        <div class="alert alert-warning">
            Brisanjem ove glavne kategorije obrisat će se i njene prazne podkategorije.
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            Ova kategorija će biti trajno obrisana.
        </div>
    }

    <form asp-action="Delete">
        <input type="hidden" asp-for="CategoryID" />
        <button type="submit" class="btn btn-danger" @(productCount > 0 ? "disabled" : "")>Obriši</button>
        <a asp-action="Index" class="btn btn-secondary">Nazad</a>
    </form>
</div>

<style>
    .delete-category-panel {
        max-width: 720px;
        background: #fff;
        border: 1px solid #f0d3d8;
        border-left: 6px solid #d82736;
        border-radius: 6px;
        padding: 22px;
    }
</style>

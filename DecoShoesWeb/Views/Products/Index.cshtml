@model IEnumerable<DecoShoesWeb.Models.Product>

@{
    ViewData["Title"] = "Admin proizvodi";
    var currentSearch = ViewData["CurrentSearch"] as string ?? string.Empty;
}

<div class="admin-products-header">
    <div>
        <h1>Proizvodi</h1>
        <a asp-action="Create" class="btn btn-primary">Dodaj novi proizvod</a>
    </div>
</div>

<form asp-action="Index" method="get" class="product-filter-bar">
    <div class="filter-field category-filter">
        <label for="categoryId">Kategorija</label>
        <select id="categoryId" name="categoryId" class="form-select" asp-items="ViewBag.CategoryFilterID"></select>
    </div>

    <div class="filter-field search-filter">
        <label for="search">Pretraga</label>
        <input id="search" name="search" value="@currentSearch" class="form-control" placeholder="Naziv, brend, boja, opis..." />
    </div>

    <div class="filter-actions">
        <button type="submit" class="btn btn-primary">Prikaži</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Očisti</a>
    </div>
</form>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success mt-3">@TempData["Message"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mt-3">@TempData["Error"]</div>
}

<table class="table align-middle admin-products-table mt-4">
    <thead>
        <tr>
            <th>Naziv</th>
            <th>Kategorija</th>
            <th>Brend</th>
            <th>Boja</th>
            <th>Cijena</th>
            <th>Popust</th>
            <th>Zaliha</th>
            <th>Brojevi</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
    var categoryName = item.Category?.ParentCategory != null
        ? $"{item.Category.ParentCategory.Name} > {item.Category.Name}"
        : item.Category?.Name ?? "-";
    var sizeSummary = item.HasSizes
        ? (item.ProductSizes.Any()
            ? string.Join(", ", item.ProductSizes.OrderBy(s => s.Size).Select(s => $"{s.Size}: {s.StockQuantity}"))
            : "Nema brojeva")
        : "-";

        <tr>
            <td><strong>@item.Name</strong></td>
            <td>@categoryName</td>
            <td>@(item.Brand ?? "-")</td>
            <td>@(item.Color ?? "-")</td>
            <td>@item.Price.ToString("0.00") KM</td>
            <td>@(item.DiscountPercent.HasValue && item.DiscountPercent > 0 ? $"{item.DiscountPercent:0.##}%" : "-")</td>
            <td>@(item.StockQuantity?.ToString() ?? "-")</td>
            <td class="size-summary">@sizeSummary</td>
            <td class="text-end admin-actions">
                @if (item.HasSizes)
                {
                    <a asp-controller="ProductSizes" asp-action="Manage" asp-route-productId="@item.ProductID" class="btn btn-sm btn-outline-primary">Brojevi</a>
                }
                <a asp-action="Edit" asp-route-id="@item.ProductID" class="btn btn-sm btn-outline-secondary">Uredi</a>
                <a asp-action="Details" asp-route-id="@item.ProductID" class="btn btn-sm btn-outline-secondary">Detalji</a>
                <a asp-action="Delete" asp-route-id="@item.ProductID" class="btn btn-sm btn-danger">Obriši</a>
            </td>
        </tr>
}
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="empty-products-state">Nema proizvoda za izabranu kategoriju ili pretragu.</div>
}

<style>
    .admin-products-header {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 18px;
    }

    .product-filter-bar {
        display: grid;
        grid-template-columns: minmax(220px, 320px) minmax(260px, 1fr) auto;
        gap: 14px;
        align-items: end;
        margin-top: 18px;
        padding: 16px;
        border: 1px solid #f7c9cf;
        border-radius: 6px;
        background: #fff1f3;
    }

    .filter-field label {
        display: block;
        font-weight: 800;
        margin-bottom: 6px;
    }

    .filter-actions {
        display: flex;
        gap: 8px;
        white-space: nowrap;
    }

    .admin-products-table thead { background: #d82736; color: #fff; }
    .admin-products-table tbody tr:hover { background: #fff1f3; }
    .admin-products-table .btn-danger { background: #d82736; border-color: #d82736; }
    .admin-actions { white-space: nowrap; }
    .size-summary { max-width: 260px; white-space: normal; color: #6f3741; font-size: 14px; }
    .admin-actions .btn-outline-primary { border-color: #d82736; color: #d82736; }
    .admin-actions .btn-outline-primary:hover { background: #d82736; color: #fff; }
    .admin-actions .btn-outline-secondary:hover { background: #ffd166; border-color: #ffd166; color: #211a1d; }

    .empty-products-state {
        padding: 18px;
        border: 1px solid #f7c9cf;
        border-radius: 6px;
        background: #fff1f3;
        font-weight: 800;
        color: #6f3741;
    }

    @@media (max-width: 900px) {
        .product-filter-bar {
            grid-template-columns: 1fr;
        }
    }
</style>

@model DecoShoesWeb.Models.CheckoutViewModel

@{
    ViewData["Title"] = "Završi narudžbu";
}

<div class="checkout-page">
    <div class="checkout-header">
        <h1>Završi narudžbu</h1>
        <a asp-action="Index" class="btn btn-outline-secondary">Nazad na korpu</a>
    </div>

    <form asp-action="Checkout" method="post" class="checkout-layout">
        @Html.AntiForgeryToken()
        <div class="checkout-form-card">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <h2>Podaci za narudžbu</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="FirstName">Ime</label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="LastName">Prezime</label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Email">Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Phone">Telefon</label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
                <div class="form-group wide">
                    <label asp-for="Address">Adresa</label>
                    <input asp-for="Address" class="form-control" />
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="City">Grad</label>
                    <input asp-for="City" class="form-control" />
                    <span asp-validation-for="City" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="PostalCode">Poštanski broj</label>
                    <input asp-for="PostalCode" class="form-control" />
                    <span asp-validation-for="PostalCode" class="text-danger"></span>
                </div>
            </div>

            <label class="save-info-option">
                <input asp-for="SaveCustomerInfo" />
                <span>
                    <strong>Sačuvaj moje podatke za iduću narudžbu</strong>
                    <small>Ime, telefon, email i adresa će se automatski popuniti sljedeći put.</small>
                </span>
            </label>

            <h2>Plaćanje</h2>
            <div class="payment-options">
                <label>
                    <input asp-for="PaymentMethod" type="radio" value="Plaćanje pouzećem" />
                    <span>Plaćanje pouzećem</span>
                </label>
                <label>
                    <input asp-for="PaymentMethod" type="radio" value="Plaćanje u radnji" />
                    <span>Plaćanje u radnji</span>
                </label>
                <label>
                    <input asp-for="PaymentMethod" type="radio" value="Kartično plaćanje" />
                    <span>Kartično plaćanje</span>
                </label>
            </div>

            <div class="card-payment-note">
                <strong>Kartično plaćanje je pripremljeno.</strong>
                <span>Trenutno se narudžba evidentira kao da čeka kartično plaćanje. Stvarnu naplatu povezujemo kada izabereš payment provider i dobiješ njihove podatke.</span>
            </div>
        </div>

        <aside class="checkout-summary">
            <h2>Pregled narudžbe</h2>
            @foreach (var item in Model.Items)
            {
                <div class="summary-item">
                    <div>
                        <strong>@item.ProductName</strong>
                        <span>@(string.IsNullOrWhiteSpace(item.Size) ? "Bez veličine" : $"Broj {item.Size}") x @item.Quantity</span>
                    </div>
                    <b>@item.Total.ToString("0.00") BAM</b>
                </div>
            }
            <div class="summary-total">
                <span>Ukupno</span>
                <strong>@Model.Total.ToString("0.00") BAM</strong>
            </div>
            <button type="submit" class="btn btn-primary">Potvrdi narudžbu</button>
        </aside>
    </form>
</div>

<style>
    .checkout-page { max-width: 1120px; margin: 0 auto; }
    .checkout-header { display: flex; align-items: center; justify-content: space-between; gap: 14px; margin-bottom: 18px; }
    .checkout-header h1 { margin: 0; font-weight: 900; color: #211a1d; }
    .checkout-layout { display: grid; grid-template-columns: 1fr 340px; gap: 22px; align-items: start; }
    .checkout-form-card, .checkout-summary { border: 1px solid #f7c9cf; border-radius: 6px; background: #fff; padding: 20px; }
    .checkout-form-card h2, .checkout-summary h2 { font-size: 20px; font-weight: 900; color: #211a1d; margin: 0 0 16px; }
    .checkout-form-card h2:not(:first-child) { margin-top: 24px; }
    .form-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
    .form-group.wide { grid-column: 1 / -1; }
    .form-group label { font-weight: 900; color: #211a1d; margin-bottom: 6px; }
    .form-control:focus { border-color: #d82736; box-shadow: 0 0 0 .2rem rgba(216, 39, 54, .15); }
    .save-info-option { display: flex; gap: 12px; align-items: flex-start; margin-top: 18px; padding: 14px; border: 1px solid #f7c9cf; border-radius: 6px; background: #fff7f8; color: #211a1d; }
    .save-info-option input { margin-top: 4px; accent-color: #d82736; }
    .save-info-option span { display: grid; gap: 3px; }
    .save-info-option small { color: #6f3741; font-weight: 700; }
    .payment-options { display: grid; gap: 10px; }
    .payment-options label { display: flex; gap: 10px; align-items: center; border: 1px solid #f7c9cf; border-radius: 6px; padding: 12px; font-weight: 900; color: #211a1d; }
    .payment-options input { accent-color: #d82736; }
    .card-payment-note { display: grid; gap: 4px; margin-top: 12px; padding: 13px 14px; border: 1px solid #f2d37a; border-radius: 6px; background: #fff9e6; color: #4f3a00; }
    .card-payment-note strong { font-weight: 900; }
    .checkout-summary { position: sticky; top: 20px; display: grid; gap: 12px; background: #fff7f8; }
    .summary-item { display: flex; justify-content: space-between; gap: 12px; border-bottom: 1px solid #f7c9cf; padding-bottom: 10px; }
    .summary-item div { display: grid; gap: 3px; }
    .summary-item span { color: #6f3741; font-weight: 700; }
    .summary-total { display: flex; justify-content: space-between; align-items: center; font-size: 20px; }
    .summary-total strong { color: #211a1d; }
    .btn-primary { background: #d82736; border-color: #d82736; font-weight: 900; }
    .btn-primary:hover { background: #b51d2a; border-color: #b51d2a; }
    .btn-outline-secondary { font-weight: 900; }
    @@media (max-width: 900px) { .checkout-layout { grid-template-columns: 1fr; } .checkout-summary { position: static; } }
    @@media (max-width: 620px) { .checkout-header { align-items: flex-start; flex-direction: column; } .form-grid { grid-template-columns: 1fr; } }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

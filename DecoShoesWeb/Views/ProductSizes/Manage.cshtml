@model DecoShoesWeb.Models.ProductSizeStockManageViewModel

@{
    ViewData["Title"] = "Brojevi proizvoda";
}

<div class="admin-header-row">
    <div>
        <h1>Brojevi proizvoda</h1>
        <p class="text-muted mb-0">@Model.ProductName</p>
    </div>
    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">Nazad na proizvode</a>
</div>

<form asp-action="Manage" method="post" class="size-stock-panel">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="ProductID" />
    <input type="hidden" asp-for="ProductName" />

    <h2>Postojeći brojevi</h2>

    @if (!Model.ExistingSizes.Any())
    {
        <div class="empty-state">Ovaj proizvod još nema unesene brojeve.</div>
    }
    else
    {
        <table class="table align-middle size-stock-table">
            <thead>
                <tr>
                    <th>Broj</th>
                    <th>Količina</th>
                    <th>Obriši</th>
                </tr>
            </thead>
            <tbody>
                @for (var i = 0; i < Model.ExistingSizes.Count; i++)
                {
                    <tr>
                        <td>
                            <input type="hidden" asp-for="ExistingSizes[i].ProductSizeID" />
                            <input asp-for="ExistingSizes[i].Size" class="form-control size-input" />
                        </td>
                        <td>
                            <input asp-for="ExistingSizes[i].StockQuantity" class="form-control quantity-input" min="0" />
                            <span asp-validation-for="ExistingSizes[i].StockQuantity" class="text-danger"></span>
                        </td>
                        <td>
                            <input asp-for="ExistingSizes[i].Delete" class="form-check-input" />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <h2 class="mt-4">Dodaj nove brojeve</h2>
    <table class="table align-middle size-stock-table">
        <thead>
            <tr>
                <th>Broj</th>
                <th>Količina</th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.NewSizes.Count; i++)
            {
                <tr>
                    <td>
                        <input asp-for="NewSizes[i].Size" class="form-control size-input" placeholder="npr. 42" />
                    </td>
                    <td>
                        <input asp-for="NewSizes[i].StockQuantity" class="form-control quantity-input" min="0" />
                        <span asp-validation-for="NewSizes[i].StockQuantity" class="text-danger"></span>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="admin-form-actions">
        <button type="submit" class="btn btn-primary">Sačuvaj brojeve</button>
        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">Odustani</a>
    </div>
</form>

<style>
    .admin-header-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: 18px;
    }

    .size-stock-panel {
        max-width: 820px;
        border: 1px solid #f7c9cf;
        border-radius: 6px;
        padding: 20px;
        background: #fff;
    }

    .size-stock-panel h2 {
        font-size: 20px;
        font-weight: 900;
        margin-bottom: 12px;
    }

    .size-stock-table thead {
        background: #d82736;
        color: #fff;
    }

    .size-input {
        max-width: 180px;
    }

    .quantity-input {
        max-width: 140px;
    }

    .empty-state {
        padding: 18px;
        background: #fff1f3;
        color: #6f3741;
        font-weight: 700;
        border-radius: 6px;
    }

    .admin-form-actions {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

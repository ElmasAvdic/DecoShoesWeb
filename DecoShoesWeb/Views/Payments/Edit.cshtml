@model DecoShoesWeb.Models.Payment
@{ ViewData["Title"] = "Uredi plaćanje"; }
<h1>Uredi plaćanje</h1>
<div class="admin-form-card"><form asp-action="Edit"><input type="hidden" asp-for="PaymentID" /><div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div><div class="form-grid two"><div class="form-group mb-3"><label asp-for="OrderID">Narudžba</label><select asp-for="OrderID" class="form-control" asp-items="ViewBag.OrderID"></select></div><div class="form-group mb-3"><label asp-for="PaymentDate">Datum plaćanja</label><input asp-for="PaymentDate" class="form-control" /></div><div class="form-group mb-3"><label asp-for="Amount">Iznos</label><input asp-for="Amount" class="form-control" /></div><div class="form-group mb-3"><label asp-for="PaymentMethod">Način plaćanja</label><select asp-for="PaymentMethod" class="form-control"><option>Gotovina</option><option>Kartica</option><option>Kartično plaćanje</option><option>Žiralno</option><option>Pouzeće</option><option>Plaćanje pouzećem</option><option>Plaćanje u radnji</option></select></div><div class="form-group mb-3"><label asp-for="PaymentStatus">Status plaćanja</label><select asp-for="PaymentStatus" class="form-control"><option>Na čekanju</option><option>Čeka kartično plaćanje</option><option>Plaćeno</option><option>Evidentirano</option><option>Odbijeno</option><option>Vraćeno</option></select></div></div><div class="admin-form-actions"><button type="submit" class="btn btn-primary">Sačuvaj</button><a asp-action="Index" class="btn btn-outline-secondary">Nazad na plaćanja</a></div></form></div>
<style>.admin-form-card{max-width:820px;border:1px solid #f7c9cf;border-radius:6px;padding:20px;background:#fff}.form-grid.two{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:0 14px}.admin-form-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:10px}label{font-weight:800;margin-bottom:6px}@@media(max-width:700px){.form-grid.two{grid-template-columns:1fr}}</style>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }

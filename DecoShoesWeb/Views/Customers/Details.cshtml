@model DecoShoesWeb.Models.Customer
@{
    ViewData["Title"] = "Detalji kupca";
}
<h1>Detalji kupca</h1>
<div class="details-card">
    <div class="details-grid"><div><span>Kupac</span><strong>@Model.FirstName @Model.LastName</strong></div><div><span>Telefon</span><strong>@(Model.Phone ?? "-")</strong></div><div><span>Email</span><strong>@(Model.Email ?? "-")</strong></div><div><span>Grad</span><strong>@(Model.City ?? "-")</strong></div><div class="span-two"><span>Adresa</span><strong>@(Model.Address ?? "-") @(Model.PostalCode ?? "")</strong></div></div>
    <div class="details-actions"><a asp-controller="Orders" asp-action="Index" asp-route-customerId="@Model.CustomerID" class="btn btn-outline-primary">Narudžbe kupca</a><a asp-action="Edit" asp-route-id="@Model.CustomerID" class="btn btn-primary">Uredi</a><a asp-action="Index" class="btn btn-outline-secondary">Nazad na kupce</a></div>
</div>
<style>.details-card{max-width:850px;border:1px solid #f7c9cf;border-radius:6px;padding:20px;background:#fff}.details-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}.details-grid div{background:#fff1f3;border-radius:6px;padding:14px}.details-grid span{display:block;color:#697386;font-weight:700;margin-bottom:4px}.details-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:20px}.span-two{grid-column:span 2}@@media(max-width:700px){.details-grid{grid-template-columns:1fr}.span-two{grid-column:auto}}</style>

@model DecoShoesWeb.Models.Customer

@{
    ViewData["Title"] = "Moji podaci";
}

<div class="profile-page">
    <div class="profile-header">
        <h1>Moji podaci</h1>
        <div class="profile-actions">
            <a asp-action="EditProfile" class="btn btn-primary">Uredi</a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Nazad u kupovinu</a>
        </div>
    </div>

    <div class="profile-card">
        <div>
            <span>Ime i prezime</span>
            <strong>@Model.FirstName @Model.LastName</strong>
        </div>
        <div>
            <span>Email</span>
            <strong>@(Model.Email ?? "-")</strong>
        </div>
        <div>
            <span>Telefon</span>
            <strong>@(Model.Phone ?? "-")</strong>
        </div>
        <div>
            <span>Adresa</span>
            <strong>@(Model.Address ?? "-")</strong>
        </div>
        <div>
            <span>Grad</span>
            <strong>@(Model.City ?? "-")</strong>
        </div>
        <div>
            <span>Poštanski broj</span>
            <strong>@(Model.PostalCode ?? "-")</strong>
        </div>
    </div>
</div>

<style>
    .profile-page { max-width: 820px; margin: 0 auto; }
    .profile-header { display: flex; align-items: center; justify-content: space-between; gap: 14px; margin-bottom: 18px; }
    .profile-page h1 { font-weight: 900; color: #211a1d; margin: 0; }
    .profile-actions { display: flex; gap: 10px; flex-wrap: wrap; }
    .btn-primary { background: #d82736; border-color: #d82736; font-weight: 900; }
    .btn-primary:hover { background: #b51d2a; border-color: #b51d2a; }
    .btn-outline-secondary { font-weight: 900; }
    .profile-card { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1px; border: 1px solid #f7c9cf; border-radius: 6px; overflow: hidden; background: #f7c9cf; }
    .profile-card div { background: #fff; padding: 18px; }
    .profile-card span { display: block; color: #6f3741; font-weight: 800; margin-bottom: 6px; }
    .profile-card strong { color: #211a1d; font-size: 17px; }
    @@media (max-width: 680px) { .profile-header { align-items: flex-start; flex-direction: column; } .profile-card { grid-template-columns: 1fr; } }
</style>

@model IEnumerable<DecoShoesWeb.Models.Category>

@{
    ViewData["Title"] = "Kategorije";
    var currentUrl = Context.Request.Path + Context.Request.QueryString;
}

<h1>Kategorije</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Dodaj novu kategoriju</a>
</p>

<table class="table align-middle category-admin-table">
    <thead>
        <tr>
            <th>Naziv</th>
            <th>Roditelj</th>
            <th>Naziv za link</th>
            <th>Redoslijed</th>
            <th>Aktivna</th>
            <th>Opis</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                <strong>@item.Name</strong>
            </td>
            <td>@(item.ParentCategory?.Name ?? "Glavna kategorija")</td>
            <td>@item.Slug</td>
            <td>@item.DisplayOrder</td>
            <td>@(item.IsActive ? "Da" : "Ne")</td>
            <td>@item.Description</td>
            <td class="text-end">
                <a asp-action="Edit" asp-route-id="@item.CategoryID" asp-route-returnUrl="@currentUrl" class="btn btn-sm btn-outline-secondary">Uredi</a>
                <a asp-action="Details" asp-route-id="@item.CategoryID" asp-route-returnUrl="@currentUrl" class="btn btn-sm btn-outline-secondary">Detalji</a>
                <a asp-action="Delete" asp-route-id="@item.CategoryID" class="btn btn-sm btn-danger">Obriši</a>
            </td>
        </tr>
}
    </tbody>
</table>

<style>
    .category-admin-table thead {
        background: #d82736;
        color: #fff;
    }

    .category-admin-table .btn-danger {
        background: #d82736;
        border-color: #d82736;
    }

    .category-admin-table .btn-outline-secondary:hover {
        background: #ffd166;
        border-color: #ffd166;
        color: #211a1d;
    }
</style>

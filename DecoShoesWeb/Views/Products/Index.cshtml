@model IEnumerable<DecoShoesWeb.Models.Product>

@{
    ViewData["Title"] = "Proizvodi";
}

<h1>Proizvodi</h1>

<p>
    <a asp-action="Create">Dodaj Novi</a>
</p>
<div class="row">
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">
            @TempData["Message"]
        </div>
    }

    <div class="container-fluid mt-4">
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-4 col-sm-6">
                    <div class="product-card">
                        <a asp-action="Details" asp-route-id="@item.ProductID" class="text-decoration-none text-dark">

                            <div class="product-image-box">
                                

                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" class="product-image" />
                                }
                                else
                                {
                                    <div class="no-image">No image</div>
                                }
                            </div>

                            <div class="product-info">
                                <p class="product-category">@(item.Category?.Name ?? "Proizvod")</p>
                                <h5 class="product-name">@item.Name</h5>
                           

                                @if (item.DiscountPercent != null && item.DiscountPercent > 0)
                                {
                                    var discountedPrice = item.Price - (item.Price * item.DiscountPercent.Value / 100);

                                    <span class="discount-label">-@item.DiscountPercent%</span>

                                    <p class="old-price">@item.Price BAM</p>
                                    <p class="product-price">@discountedPrice.ToString("0.00") BAM</p>
                                }
                                else
                                {
                                    <p class="product-price">@item.Price BAM</p>
                                }
                            </div>

                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
<style>
    .product-card {
        border: none;
        background: white;
        transition: 0.2s;
    }

        .product-card:hover {
            transform: translateY(-3px);
        }

    .product-image-box {
        position: relative;
        background: #f7f7f7;
        height: 360px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .product-image {
        max-width: 90%;
        max-height: 90%;
        object-fit: contain;
    }

    .discount-label {
        position: absolute;
        top: 14px;
        left: 14px;
        border: 1px solid red;
        color: red;
        font-size: 13px;
        padding: 6px 12px;
        background: white;
        z-index: 2;
    }

    .product-info {
        padding-top: 18px;
    }

    .product-category {
        color: gray;
        margin-bottom: 6px;
    }

    .product-name {
        font-size: 17px;
        font-weight: 600;
        margin-bottom: 26px;
    }

    .product-price {
        font-size: 20px;
        font-weight: 700;
    }

    .no-image {
        color: #aaa;
        font-size: 18px;
    }

    .old-price {
        text-decoration: line-through;
        color: gray;
        margin-bottom: 4px;
    }

    .product-price {
        font-size: 20px;
        font-weight: 700;
    }
</style>
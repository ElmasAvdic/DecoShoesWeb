@model IEnumerable<DecoShoesWeb.Models.Category>

@{
    ViewData["Title"] = "Kategorije";
}

<h1>Kategorije</h1>

<p>
    <a asp-action="Create">Dodaj Novu</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                Naziv
            </th>
            <th>
                Opis
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.CategoryID">Uredi</a> |
                <a asp-action="Details" asp-route-id="@item.CategoryID">Detalji</a> |
                <a asp-action="Delete" asp-route-id="@item.CategoryID">Obriši</a>
            </td>
        </tr>
}
    </tbody>
</table>

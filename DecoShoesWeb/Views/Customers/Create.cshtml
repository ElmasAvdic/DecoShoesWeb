@model DecoShoesWeb.Models.Customer
@{
    ViewData["Title"] = "Dodaj kupca";
}
<h1>Dodaj kupca</h1>
<div class="admin-form-card">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="form-grid two">
            <div class="form-group mb-3"><label asp-for="FirstName">Ime</label><input asp-for="FirstName" class="form-control" /><span asp-validation-for="FirstName" class="text-danger"></span></div>
            <div class="form-group mb-3"><label asp-for="LastName">Prezime</label><input asp-for="LastName" class="form-control" /><span asp-validation-for="LastName" class="text-danger"></span></div>
            <div class="form-group mb-3"><label asp-for="Phone">Telefon</label><input asp-for="Phone" class="form-control" /></div>
            <div class="form-group mb-3"><label asp-for="Email">Email</label><input asp-for="Email" class="form-control" /></div>
            <div class="form-group mb-3 span-two"><label asp-for="Address">Adresa</label><input asp-for="Address" class="form-control" /></div>
            <div class="form-group mb-3"><label asp-for="City">Grad</label><input asp-for="City" class="form-control" /></div>
            <div class="form-group mb-3"><label asp-for="PostalCode">Poštanski broj</label><input asp-for="PostalCode" class="form-control" /></div>
        </div>
        <div class="admin-form-actions"><button type="submit" class="btn btn-primary">Sačuvaj</button><a asp-action="Index" class="btn btn-outline-secondary">Nazad na kupce</a></div>
    </form>
</div>
<style>.admin-form-card{max-width:820px;border:1px solid #f7c9cf;border-radius:6px;padding:20px;background:#fff}.form-grid.two{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:0 14px}.span-two{grid-column:span 2}.admin-form-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:10px}label{font-weight:800;margin-bottom:6px}@@media(max-width:700px){.form-grid.two{grid-template-columns:1fr}.span-two{grid-column:auto}}</style>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }

@model IEnumerable<DecoShoesWeb.Models.ProductSize>

@{
    ViewData["Title"] = "Veličine Proizvoda";
}

<h1>Veličine Proizvoda</h1>

<p>
    <a asp-action="Create">Dodaj Novu</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                Proizvod
            </th>
            <th>
                Veličina
            </th>
            <th>
                Količina u Lageru
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Product.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Size)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.StockQuantity)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ProductSizeID">Uredi</a> |
                <a asp-action="Details" asp-route-id="@item.ProductSizeID">Detalji</a> |
                <a asp-action="Delete" asp-route-id="@item.ProductSizeID">Obriši</a>
            </td>
        </tr>
}
    </tbody>
</table>

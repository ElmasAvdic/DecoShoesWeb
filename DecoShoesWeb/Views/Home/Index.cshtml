    .product-meta { min-height: 44px; margin-bottom: 8px; }
    .product-brand, .product-color { font-size: 13px; color: #6f3741; margin-bottom: 5px; }
    .product-price-container { margin-top: auto; padding-top: 10px; border-top: 1px solid #f6dde1; }
    .product-price { font-size: 21px; font-weight: 900; color: #211a1d; }
    .product-discount, .discount-badge { color: #d82736; font-weight: 900; }
    .original-price { font-size: 14px; color: #8f5962; text-decoration: line-through; margin-right: 6px; }
    .discount-badge { position: absolute; top: 10px; left: 10px; background-color: #fff; border: 1px solid #ffd166; padding: 5px 10px; font-size: 13px; }
    .wishlist-product-btn { position: absolute; top: 10px; right: 10px; width: 38px; height: 38px; border-radius: 50%; border: 1px solid #f7c9cf; background: #fff; color: #d82736; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 8px 18px rgba(33, 26, 29, .12); }
    .wishlist-product-btn svg { width: 21px; height: 21px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
    .wishlist-product-btn.active { background: #d82736; color: #fff; border-color: #d82736; }
    .wishlist-product-btn.active svg { fill: currentColor; }
    .stock-status { font-size: 13px; margin-top: 8px; font-weight: 900; color: #c98a00; }
    .add-to-cart-btn { margin-top: 12px; padding: 10px; background-color: #d82736; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: 900; }
    .add-to-cart-btn:hover { background-color: #a91524; }
    .no-products { padding: 42px; background: #fff7f8; color: #6f3741; font-weight: 800; text-align: center; }
    .account-modal-backdrop { position: fixed; inset: 0; background: rgba(33, 26, 29, .58); z-index: 1000; display: none; align-items: center; justify-content: center; padding: 24px; }
    .account-modal-backdrop.is-open { display: flex; }
    .account-modal { width: min(720px, 100%); background: #fff; border-radius: 6px; box-shadow: 0 22px 60px rgba(33, 26, 29, .28); padding: 30px; position: relative; }
    .account-modal-close { position: absolute; top: 14px; right: 16px; width: 34px; height: 34px; border: none; background: transparent; color: #6f3741; font-size: 28px; line-height: 1; cursor: pointer; }
    .account-modal-title { text-align: center; font-size: 19px; font-weight: 900; margin: 6px 0 20px; color: #211a1d; }
    .account-tabs { display: flex; justify-content: center; gap: 10px; margin-bottom: 20px; }
    .account-tab { border: 1px solid #f7c9cf; background: #fff; color: #6f3741; border-radius: 999px; padding: 9px 18px; font-weight: 900; cursor: pointer; }
    .account-tab.active { background: #d82736; border-color: #d82736; color: #fff; }
    .account-form { display: none; max-width: 440px; margin: 0 auto; }
    .account-form.active { display: block; }
    .account-form label { display: block; font-weight: 900; color: #211a1d; margin: 14px 0 7px; }
    .account-form input { width: 100%; border: 1px solid #d9b9be; border-radius: 999px; padding: 12px 16px; font-weight: 700; outline: none; }

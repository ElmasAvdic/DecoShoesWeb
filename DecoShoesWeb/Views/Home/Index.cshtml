    .utility-text { font-size: 12px; font-weight: 900; }
    .icon-count { position: absolute; top: -6px; right: -5px; min-width: 18px; height: 18px; padding: 0 5px; border-radius: 999px; background: #0b6b45; color: #fff; font-size: 11px; font-weight: 900; display: inline-flex; align-items: center; justify-content: center; }
    .utility-dropdown { position: absolute; top: calc(100% + 10px); right: 0; width: 270px; background: #fff; border: 1px solid #f7c9cf; box-shadow: 0 14px 32px rgba(33, 26, 29, .16); padding: 22px; text-align: center; z-index: 30; opacity: 0; visibility: hidden; transform: translateY(8px); transition: opacity .15s ease, transform .15s ease, visibility .15s ease; }

@model DecoShoesWeb.Models.Order
@{ ViewData["Title"] = "Uredi narudžbu"; }
<h1>Uredi narudžbu</h1>
<div class="admin-form-card"><form asp-action="Edit"><input type="hidden" asp-for="OrderID" /><div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div><div class="form-grid two"><div class="form-group mb-3"><label asp-for="CustomerID">Kupac</label><select asp-for="CustomerID" class="form-control" asp-items="ViewBag.CustomerID"></select></div><div class="form-group mb-3"><label asp-for="OrderDate">Datum narudžbe</label><input asp-for="OrderDate" class="form-control" /></div><div class="form-group mb-3"><label asp-for="TotalAmount">Ukupan iznos</label><input asp-for="TotalAmount" class="form-control" /></div><div class="form-group mb-3"><label asp-for="Status">Status</label><select asp-for="Status" class="form-control"><option>Nova</option><option>U obradi</option><option>Poslano</option><option>Završeno</option><option>Otkazano</option></select></div></div><div class="admin-form-actions"><button type="submit" class="btn btn-primary">Sačuvaj</button><a asp-action="Index" class="btn btn-outline-secondary">Nazad na narudžbine</a></div></form></div>
<style>.admin-form-card{max-width:820px;border:1px solid #f7c9cf;border-radius:6px;padding:20px;background:#fff}.form-grid.two{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:0 14px}.admin-form-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:10px}label{font-weight:800;margin-bottom:6px}@@media(max-width:700px){.form-grid.two{grid-template-columns:1fr}}</style>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }

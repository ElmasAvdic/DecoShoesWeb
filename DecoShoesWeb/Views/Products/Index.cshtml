@model IEnumerable<DecoShoesWeb.Models.Product>

@{
    ViewData["Title"] = "Admin proizvodi";
}

<h1>Proizvodi</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Dodaj novi proizvod</a>
</p>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success mt-3">@TempData["Message"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mt-3">@TempData["Error"]</div>
}

<table class="table align-middle admin-products-table mt-4">
    <thead>
        <tr>
            <th>Naziv</th>
            <th>Kategorija</th>
            <th>Brend</th>
            <th>Boja</th>
            <th>Cijena</th>
            <th>Popust</th>
            <th>Zaliha</th>
            <th>Brojevi</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
    var categoryName = item.Category?.ParentCategory != null
        ? $"{item.Category.ParentCategory.Name} > {item.Category.Name}"
        : item.Category?.Name ?? "-";
    var sizeSummary = item.HasSizes
        ? (item.ProductSizes.Any()
            ? string.Join(", ", item.ProductSizes.OrderBy(s => s.Size).Select(s => $"{s.Size}: {s.StockQuantity}"))
            : "Nema brojeva")
        : "Ne";

        <tr>
            <td><strong>@item.Name</strong></td>
            <td>@categoryName</td>
            <td>@(item.Brand ?? "-")</td>
            <td>@(item.Color ?? "-")</td>
            <td>@item.Price.ToString("0.00") KM</td>
            <td>@(item.DiscountPercent.HasValue && item.DiscountPercent > 0 ? $"{item.DiscountPercent:0.##}%" : "-")</td>
            <td>@(item.StockQuantity?.ToString() ?? "-")</td>
            <td class="size-summary">@sizeSummary</td>
            <td class="text-end admin-actions">
                <a asp-controller="ProductSizes" asp-action="Manage" asp-route-productId="@item.ProductID" class="btn btn-sm btn-outline-primary">Brojevi</a>
                <a asp-action="Edit" asp-route-id="@item.ProductID" class="btn btn-sm btn-outline-secondary">Uredi</a>
                <a asp-action="Details" asp-route-id="@item.ProductID" class="btn btn-sm btn-outline-secondary">Detalji</a>
                <a asp-action="Delete" asp-route-id="@item.ProductID" class="btn btn-sm btn-danger">Obriši</a>
            </td>
        </tr>
}
    </tbody>
</table>

<style>
    .admin-products-table thead {
        background: #d82736;
        color: #fff;
    }

    .admin-products-table tbody tr:hover {
        background: #fff1f3;
    }

    .admin-products-table .btn-danger {
        background: #d82736;
        border-color: #d82736;
    }

    .admin-actions {
        white-space: nowrap;
    }

    .size-summary {
        max-width: 260px;
        white-space: normal;
        color: #6f3741;
        font-size: 14px;
    }

    .admin-actions .btn-outline-primary {
        border-color: #d82736;
        color: #d82736;
    }

    .admin-actions .btn-outline-primary:hover {
        background: #d82736;
        color: #fff;
    }

    .admin-actions .btn-outline-secondary:hover {
        background: #ffd166;
        border-color: #ffd166;
        color: #211a1d;
    }
</style>
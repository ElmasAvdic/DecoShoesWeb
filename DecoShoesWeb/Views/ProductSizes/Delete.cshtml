@model DecoShoesWeb.Models.ProductSize

@{
    ViewData["Title"] = "Obriši broj";
}

<h1>Obriši broj</h1>

<div class="delete-card">
    <h2>Da li želiš obrisati ovaj broj?</h2>
    <p>Ovo će ukloniti broj iz lagera za odabrani proizvod.</p>

    <div class="delete-summary">
        <div>
            <span>Proizvod</span>
            <strong>@(Model.Product?.Name ?? "-")</strong>
        </div>
        <div>
            <span>Broj / veličina</span>
            <strong>@Model.Size</strong>
        </div>
        <div>
            <span>Količina</span>
            <strong>@Model.StockQuantity</strong>
        </div>
    </div>

    <form asp-action="Delete" class="delete-actions">
        <input type="hidden" asp-for="ProductSizeID" />
        <button type="submit" class="btn btn-danger">Obriši</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Nazad na veličine</a>
    </form>
</div>

<style>
    .delete-card { max-width: 760px; border: 1px solid #f7c9cf; border-radius: 6px; padding: 20px; background: #fff; }
    .delete-card h2 { font-size: 22px; font-weight: 900; margin-bottom: 6px; }
    .delete-card p { color: #697386; }
    .delete-summary { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; margin: 18px 0; }
    .delete-summary div { background: #fff1f3; border-radius: 6px; padding: 14px; }
    .delete-summary span { display: block; color: #697386; font-weight: 700; margin-bottom: 4px; }
    .delete-actions { display: flex; gap: 10px; flex-wrap: wrap; }
    @@media (max-width: 700px) { .delete-summary { grid-template-columns: 1fr; } }
</style>

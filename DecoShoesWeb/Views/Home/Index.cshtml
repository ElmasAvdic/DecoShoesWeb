@using DecoShoesWeb.Models
@using System.Globalization
@using System.Text.Json
@model List<Product>
@{
    ViewData["Title"] = "DecoShoes";
    var rootCategories = (List<Category>)(ViewData["RootCategories"] ?? new List<Category>());
    var subcategoriesByParent = (Dictionary<int, List<Category>>)(ViewData["SubcategoriesByParent"] ?? new Dictionary<int, List<Category>>());
    var selectedCategoryId = (int?)ViewData["SelectedCategoryId"];
    var selectedRootCategoryId = (int?)ViewData["SelectedRootCategoryId"];
    var selectedCategory = (Category?)ViewData["SelectedCategory"];
    var currentFilter = (string?)ViewData["CurrentFilter"];
    var currentSearch = (string?)ViewData["CurrentSearch"];
    var currentSize = (string?)ViewData["CurrentSize"];
    var currentColor = (string?)ViewData["CurrentColor"];
    var currentMinPrice = (decimal?)ViewData["CurrentMinPrice"];
    var currentMaxPrice = (decimal?)ViewData["CurrentMaxPrice"];
    var currentSort = (string?)ViewData["CurrentSort"];
    var showAll = ViewData["ShowAll"] is bool showAllValue && showAllValue;
    var isHomeShowcase = ViewData["IsHomeShowcase"] is bool homeShowcaseValue && homeShowcaseValue;
    var availableColors = (List<string>)(ViewData["AvailableColors"] ?? new List<string>());
    var availableSizes = (List<string>)(ViewData["AvailableSizes"] ?? new List<string>());
    var customerName = Context.Session.GetString("CustomerName");
    var customerId = Context.Session.GetInt32("CustomerID");
    var wishlistJson = Context.Session.GetString("Wishlist");
    var wishlistIds = string.IsNullOrWhiteSpace(wishlistJson)
        ? new List<int>()
        : JsonSerializer.Deserialize<List<int>>(wishlistJson) ?? new List<int>();
    var wishlistCount = wishlistIds.Count;
    var cartJson = Context.Session.GetString("Cart");
    var cartItems = string.IsNullOrWhiteSpace(cartJson)
        ? new List<CartItem>()
        : JsonSerializer.Deserialize<List<CartItem>>(cartJson) ?? new List<CartItem>();
    var cartCount = cartItems.Sum(item => item.Quantity);
    var activeCategoryRouteId = selectedCategoryId;
    var allProductsLabel = selectedCategory?.Name ?? (string.IsNullOrWhiteSpace(currentSearch) ? "Svi proizvodi" : $"Pretraga: {currentSearch}");
    var storeMapUrl = "https://www.google.com/maps/place/Deco+Shoes/@44.4389027,18.1445395,17z/data=!3m1!4b1!4m6!3m5!1s0x475eeb2a697a892b:0x83e3ede6b82b951d!8m2!3d44.4389027!4d18.1471144!16s%2Fg%2F11b_05bsyn";
    var accountModal = TempData["AccountModal"]?.ToString();
    var accountError = TempData["AccountError"]?.ToString();
    var isAccountModalOpen = accountModal == "login" || accountModal == "register";
    var currentMinPriceText = currentMinPrice?.ToString("0.##", CultureInfo.InvariantCulture);
    var currentMaxPriceText = currentMaxPrice?.ToString("0.##", CultureInfo.InvariantCulture);
    var hasAdvancedFilters = !string.IsNullOrWhiteSpace(currentSize)
        || !string.IsNullOrWhiteSpace(currentColor)
        || currentMinPrice.HasValue
        || currentMaxPrice.HasValue;
    var showcaseProducts = Model.Count == 0
        ? new List<Product>()
        : Enumerable.Range(0, 14).Select(index => Model[index % Model.Count]).ToList();
    ViewData["WishlistIds"] = wishlistIds;
}

<style>
    .shop-shell { max-width: 1280px; margin: 0 auto; }

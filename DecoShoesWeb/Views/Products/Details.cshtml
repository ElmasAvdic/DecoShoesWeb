@model DecoShoesWeb.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<h1>@Model.Name</h1>

@if (TempData["Message"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="product-details-page">
    <div class="product-gallery">
        <div class="main-image-box">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="main-product-image" alt="@Model.Name" />
            }
            else
            {
                <div class="no-image">Nema slike</div>
            }
        </div>
    </div>

    <div class="product-details-info">
        <p class="product-category">@(Model.Category?.Name ?? "Proizvod")</p>

        @if (Model.DiscountPercent != null && Model.DiscountPercent > 0)
        {
            var discountedPrice = Model.Price - (Model.Price * Model.DiscountPercent.Value / 100);
            <p class="old-price">@Model.Price BAM</p>
            <p class="details-price">@discountedPrice.ToString("0.00") BAM</p>
        }
        else
        {
            <p class="details-price">@Model.Price BAM</p>
        }

        <hr />

        <div id="stockMessage" class="alert alert-danger" style="display: none; margin-bottom: 15px;">
            <span id="stockMessageText"></span>
        </div>

        <form asp-controller="Cart" asp-action="AddToCart" method="post" onsubmit="return validateForm()" class="cart-form-panel">
            <input type="hidden" name="productId" value="@Model.ProductID" />

            @if (Model.HasSizes)
            {
                <h5>Izaberi veličinu</h5>

                <div class="size-grid">
                    @foreach (var size in Model.ProductSizes.OrderBy(s => s.Size))
                    {
                        if (size.StockQuantity > 0)
                        {
                            <label class="size-option">
                                <input type="radio" name="productSizeId" value="@size.ProductSizeID" data-stock="@size.StockQuantity" data-size="@size.Size" class="size-input" />
                                <span>@size.Size</span>
                            </label>
                        }
                        else
                        {
                            <div class="size-option disabled">
                                <span>@size.Size</span>
                            </div>
                        }
                    }
                </div>
            }
            else
            {
                <input type="hidden" id="productStock" value="@(Model.StockQuantity ?? 0)" />
            }

            <div class="quantity-box">
                <label>Količina</label>
                <input type="number" name="quantity" value="1" min="1" class="form-control" id="quantityInput" onchange="validateQuantity()" />
            </div>

            <button type="submit" class="btn btn-danger add-cart-btn" id="submitBtn">
                Dodaj u korpu
            </button>
        </form>

        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <div class="customer-description">
                <strong>Opis</strong>
                <p>@Model.Description</p>
            </div>
        }

        <button type="button" class="btn btn-outline-secondary back-products-btn" onclick="goBackToShopping()">Nazad u kupovinu</button>
    </div>
</div>

<style>
    .product-details-page {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 40px;
        margin-top: 30px;
    }

    .main-image-box {
        background: #f6f6f6;
        min-height: 620px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
    }

    .main-product-image {
        max-width: 90%;
        max-height: 560px;
        object-fit: contain;
    }

    .product-category {
        color: #777;
        margin-bottom: 4px;
    }

    .details-price {
        font-size: 22px;
        font-weight: 700;
        margin-top: 14px;
    }

    .old-price {
        text-decoration: line-through;
        color: #8f5962;
        margin-bottom: 2px;
    }

    .size-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 8px;
        margin-top: 14px;
        margin-bottom: 20px;
    }

    .size-option input {
        display: none;
    }

    .size-option span,
    .size-option.disabled span {
        display: block;
        border: 1px solid #ccc;
        padding: 14px;
        text-align: center;
        border-radius: 4px;
        cursor: pointer;
        font-weight: 600;
    }

    .size-option input:checked + span {
        border: 2px solid #d82736;
    }

    .size-option.disabled span {
        color: #aaa;
        background: #f2f2f2;
        text-decoration: line-through;
        cursor: not-allowed;
    }

    .quantity-box {
        margin-bottom: 20px;
    }

    .quantity-box input {
        max-width: 120px;
    }

    .add-cart-btn {
        width: 100%;
        padding: 15px;
        font-size: 17px;
        border-radius: 30px;
    }

    .customer-description {
        margin-top: 22px;
        padding: 16px 18px;
        background: #fff1f3;
        border: 1px solid #f7c9cf;
        border-radius: 6px;
    }

    .customer-description strong {
        display: block;
        margin-bottom: 6px;
    }

    .customer-description p {
        margin: 0;
    }

    .back-products-btn {
        margin-top: 22px;
        border-color: #d82736;
        color: #a91524;
        font-weight: 700;
    }

    .back-products-btn:hover {
        background: #fff1f3;
        border-color: #a91524;
        color: #8f1420;
    }

    #stockMessage {
        border-radius: 5px;
        padding: 12px 15px;
        font-weight: 500;
        margin-bottom: 15px;
    }

    #stockMessage.alert-danger {
        background-color: #f8d7da;
        border: 1px solid #f5c6cb;
        color: #721c24;
    }

    .add-cart-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed !important;
    }

    @@media (max-width: 900px) {
        .product-details-page {
            grid-template-columns: 1fr;
        }

        .main-image-box {
            min-height: 360px;
        }
    }
</style>

<script>
    function validateForm() {
        const selectedSize = document.querySelector('input[name="productSizeId"]:checked');
        const quantity = parseInt(document.getElementById('quantityInput').value);
        const productStockInput = document.getElementById('productStock');
        const messageDiv = document.getElementById('stockMessage');
        const messageText = document.getElementById('stockMessageText');

        messageDiv.style.display = 'none';

        if (quantity < 1) {
            messageText.textContent = 'Količina mora biti najmanje 1!';
            messageDiv.style.display = 'block';
            return false;
        }

        if (productStockInput) {
            const stock = parseInt(productStockInput.value);

            if (quantity > stock) {
                messageText.textContent = `Nema dovoljno dostupnih komada. Dostupno je: ${stock}`;
                messageDiv.style.display = 'block';
                return false;
            }

            return true;
        }

        if (!selectedSize) {
            messageText.textContent = 'Molimo izaberite veličinu!';
            messageDiv.style.display = 'block';
            return false;
        }

        const stock = parseInt(selectedSize.getAttribute('data-stock'));
        const size = selectedSize.getAttribute('data-size');

        if (quantity > stock) {
            messageText.textContent = `Nema dovoljno dostupnih komada za veličinu ${size}. Dostupno je: ${stock}`;
            messageDiv.style.display = 'block';
            return false;
        }

        return true;
    }

    function validateQuantity() {
        const selectedSize = document.querySelector('input[name="productSizeId"]:checked');
        const quantity = parseInt(document.getElementById('quantityInput').value) || 1;
        const productStockInput = document.getElementById('productStock');
        const messageDiv = document.getElementById('stockMessage');
        const messageText = document.getElementById('stockMessageText');
        const submitBtn = document.getElementById('submitBtn');

        messageDiv.style.display = 'none';

        if (productStockInput) {
            const stock = parseInt(productStockInput.value);

            if (quantity > stock) {
                messageText.textContent = `Nema dovoljno dostupnih komada. Dostupno je: ${stock}`;
                messageDiv.style.display = 'block';
                submitBtn.disabled = true;
            } else if (quantity < 1) {
                messageText.textContent = 'Količina mora biti najmanje 1!';
                messageDiv.style.display = 'block';
                submitBtn.disabled = true;
            } else {
                submitBtn.disabled = false;
            }
        } else if (selectedSize) {
            const stock = parseInt(selectedSize.getAttribute('data-stock'));
            const size = selectedSize.getAttribute('data-size');

            if (quantity > stock) {
                messageText.textContent = `Nema dovoljno dostupnih komada za veličinu ${size}. Dostupno je: ${stock}`;
                messageDiv.style.display = 'block';
                submitBtn.disabled = true;
            } else if (quantity < 1) {
                messageText.textContent = 'Količina mora biti najmanje 1!';
                messageDiv.style.display = 'block';
                submitBtn.disabled = true;
            } else {
                submitBtn.disabled = false;
            }
        }
    }

    document.querySelectorAll('.size-input').forEach(input => {
        input.addEventListener('change', validateQuantity);
    });

    window.addEventListener('load', validateQuantity);
</script>

